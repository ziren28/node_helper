# ============================================================
# node_helper V3 配置
# 所有字段都可省略;空值 = 不启用该规则
# ============================================================

# ─── 总开关 ───
# on / off  — off 时整个 hook 旁路
CLAUDE_INTERCEPT=on

# ─── 拦截目标 ───
# 只拦 hostname 以此结尾的请求
TARGET_HOST_SUFFIX=anthropic.com

# ─── 日志 ───
# LOG_MODE:  off | stderr | file
#   stderr  - 一行摘要打到 Claude CLI 的 stderr(会跟输出混)
#   file    - 追加 JSONL 到 LOG_FILE
#   off     - 不写本地;viewer(:8787)起着的话仍会送
LOG_MODE=file
LOG_FILE=%TEMP%\node-helper-intercept.jsonl
LOG_MASK_AUTH=true

# 可选 viewer(旧版 server.js):如果它起着就会送数据,不起就静默丢
VIEWER_URL=http://127.0.0.1:8787/log

# ─── 请求头改写 ───
# 空=不改。填 'Bearer sk-ant-api03-xxx' 启用替换
HEADER_AUTH_REPLACE=

# 空=不改;逗号分隔列表 = 整替换 anthropic-beta
HEADER_BETA_REPLACE=
# 空=不改;逗号分隔 = 从原 beta 列表删这几项(跟 REPLACE 二选一)
HEADER_BETA_DROP=

# ─── <system-reminder> 清理(可开关 + 可匹配)───
# STRIP_REMINDERS_MODE:
#   off     - 什么都不剥
#   matched - 读 STRIP_REMINDERS_MATCHES_FILE 的每行模式,命中则剥掉整个
#             <system-reminder>...</system-reminder> 块;不命中保留
#   all     - 剥掉所有 <system-reminder>...</system-reminder>(最激进,慎用)
STRIP_REMINDERS_MODE=matched
# matched 模式下读的规则文件。路径相对 intercept.cjs 所在目录,或绝对路径
# 文件格式:每行一条,'#' 注释;'re:' 前缀=正则,其它=不分大小写子串
STRIP_REMINDERS_MATCHES_FILE=./prompts/strip_reminders.txt

# ─── body 改写:JSON 层 ───
# 空 = 不改;整数 = 上限(原值 > cap 时才砍)
MAX_TOKENS_CAP=
# 空 = 不改;整数 = 强制(优先级高于 CAP)
MAX_TOKENS_FORCE=
# 思考预算 budget_tokens
BUDGET_CAP=
BUDGET_FORCE=
# true = 整个删 thinking 字段
DISABLE_THINKING=false

# ─── metadata 改写 ───
# 空=不改;真值=覆盖该字段(改 session_id 会让 prompt 缓存失效)
FAKE_DEVICE_ID=
FAKE_ACCOUNT_UUID=
FAKE_SESSION_ID=
# true = 整个删 metadata 字段(比 fake 更暴力)
STRIP_METADATA=false

# ─── system[2] 改写 ───
# 文件路径(相对 intercept.cjs 所在目录,或绝对路径)。空 = 不改
#
# SYSTEM_REPLACE_FILE: 替换 system[2] 里的 "# System" 那一段
#   - 从 "# System" 开始,到下一个 "# X" 前结束
#   - 其它段(IMPORTANT 引言 / Doing tasks / Using your tools / Tone / Output efficiency)保留
#   - 文件可以包含或省略 "# System" 行,都能识别
SYSTEM_REPLACE_FILE=./prompts/system.txt

# 整个 system[2] 一次性替换(最激进,失去其它段;跟上面互斥,这个优先)
SYSTEM_FULL_REPLACE_FILE=

# 在 system[2] 最前 / 最后追加一段
SYSTEM_PREFIX_FILE=
SYSTEM_SUFFIX_FILE=

# 通用正则/子串替换(细粒度,在 # System 段替换之前执行)
# 默认规则文件里已预置"删 2 条 IMPORTANT 红线"
# 支持 'pattern' 删除 或 'pattern => replacement' 替换
SYSTEM_PATTERNS_FILE=./prompts/system_patterns.txt
